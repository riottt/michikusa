# -----------------------------------------------------------------------------
# Local mode: copy to .env.local. With no API keys, all screens run in DEMO_MODE.
# -----------------------------------------------------------------------------
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENT_SERVICE_URL=http://127.0.0.1:8081
AGENT_SHARED_SECRET=local-development-only
# Private Cloud Run agent URL. Leave blank for local development.
AGENT_SERVICE_AUDIENCE=

# Browser map. Restrict this key by HTTP referrer and API in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAP_ID=

# Server-side Maps Platform calls used by the ADK agent.
GOOGLE_MAPS_SERVER_API_KEY=

# Gemini through Google Cloud Agent Platform (recommended on Cloud Run).
# GOOGLE_GENAI_USE_ENTERPRISE is the current ADK setting; the older
# GOOGLE_GENAI_USE_VERTEXAI name is still accepted by config.py as an alias.
GOOGLE_GENAI_USE_ENTERPRISE=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-3.5-flash

# Alternative local Gemini Developer API access.
GOOGLE_API_KEY=

# Google Calendar OAuth. Redirect URI must match the Cloud Console setting.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/callback
# Use a long random string in production. Tokens are encrypted at rest.
TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-value

# Turso. Local default is file:data/michikusa.db.
TURSO_DATABASE_URL=file:data/michikusa.db
TURSO_AUTH_TOKEN=
