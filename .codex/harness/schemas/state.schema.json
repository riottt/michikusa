{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://michikusa.local/schemas/state.schema.json",
  "title": "MICHIKUSA harness runtime state",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "slug", "goal", "phase", "completed", "iteration", "created_at", "updated_at", "plan", "implementation", "review", "history"],
  "properties": {
    "version": { "const": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 },
    "goal": { "type": "string", "minLength": 1 },
    "phase": { "enum": ["plan", "implementation", "review", "complete"] },
    "completed": { "type": "boolean" },
    "iteration": { "type": "integer", "minimum": 1 },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "updated_at": { "$ref": "#/$defs/timestamp" },
    "plan": { "$ref": "#/$defs/phaseState" },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifact", "actor_id", "receipts", "receipt_signatures"],
      "properties": {
        "status": { "enum": ["blocked", "success"] },
        "artifact": { "$ref": "#/$defs/nullableArtifact" },
        "actor_id": { "$ref": "#/$defs/nullableActor" },
        "receipts": {
          "type": "array",
          "maxItems": 3,
          "items": { "type": "string", "pattern": "^\\.codex/harness/runtime/[a-z0-9-]+/receipts/[1-9][0-9]*/(red|green|final)\\.json$" }
        },
        "receipt_signatures": {
          "type": "array",
          "maxItems": 3,
          "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "review": { "$ref": "#/$defs/reviewState" },
    "history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at", "action", "summary", "iteration"],
        "properties": {
          "at": { "$ref": "#/$defs/timestamp" },
          "action": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "summary": { "type": "string", "minLength": 1 },
          "iteration": { "type": "integer", "minimum": 1 }
        }
      }
    }
  },
  "$defs": {
    "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$" },
    "nullableActor": { "type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,63}$" },
    "nullableArtifact": { "type": ["string", "null"], "pattern": "^\\.codex/harness/runtime/[a-z0-9-]+/artifacts/[A-Za-z0-9._-]+\\.json$" },
    "phaseState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifact", "actor_id"],
      "properties": {
        "status": { "enum": ["pending", "ready"] },
        "artifact": { "$ref": "#/$defs/nullableArtifact" },
        "actor_id": { "$ref": "#/$defs/nullableActor" }
      }
    },
    "reviewState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifact", "actor_id"],
      "properties": {
        "status": { "enum": ["blocked", "approved", "changes_requested"] },
        "artifact": { "$ref": "#/$defs/nullableArtifact" },
        "actor_id": { "$ref": "#/$defs/nullableActor" }
      }
    }
  }
}
